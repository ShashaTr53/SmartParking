@{
    ViewData["Title"] = "Register";
}

<h2>Créer un compte</h2>

<form asp-action="Register" method="post">
    <div class="form-group">
        <label for="email">Email</label>
        <input type="email" class="form-control" id="email" name="email" required />
    </div>
    <div class="form-group">
        <label for="password">Mot de passe</label>
        <input type="password" class="form-control" id="password" name="password" minlength="6" required />
    </div>
    <div class="form-group">
        <label for="confirmPassword">Confirmer le mot de passe</label>
        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" minlength="6" required />
    </div>
    <button type="submit" class="btn btn-primary mt-2">S'inscrire</button>
</form>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mt-3">@TempData["SuccessMessage"]</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3">
        <ul>
        @foreach (var m in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <li>@m.ErrorMessage</li>
        }
        </ul>
    </div>
}
